{% comment %}
  ============================================================
  BOCS Widget v2 — Theme App Extension Block
  ============================================================
  Multi-step subscription wizard OR single-page layout.
  Controlled by bocs.flow.layoutMode ('wizard' | 'single').

  Wizard mode: Pack → Frequency → Products → Subscribe
    - Progress indicator (step-bar-labels, dots, fraction, none)
    - Transitions: slide-horizontal, slide-vertical, fade, instant

  CSS from backend (all 5 sources; block id is applied at runtime, API never sends it):
    1. Progress Bar CSS
       State: flow.progressBarCss
       Scaffold: .widget-progress-bar { }, .widget-progress-bar .step-dot { }, etc.
    2. Step CSS (one per step, steps 1–4)
       State: flow.stepContent[n].css
       Scaffold: .step--pack-size { }, .step--frequency { }, .step--products { }, .step--review { }
       Note: Widget currently renders steps 1–3 only; step 4 CSS is injected for when review step exists.
    3. Inline CSS
       State: theming.customCss
       Used when: theming.customStyleMode === 'inline'
    4. External Stylesheet URL
       State: theming.customCssUrl
       Used when: theming.customStyleMode === 'external' (injected as <link>)
    5. Card CSS (one per frequency, within each pack size)
       State: packSizes[x].frequencies[y].cardCss
       Scaffold: .freq-card--{frequency-name-lowercase} { }

  Theming:
    - CSS variables from bocs.theming.colors

  Checkout: POST { items: [{ variantId, sellingPlanId, quantity }] }
  ============================================================
{% endcomment %}

{%- liquid
  assign block_id = 'bocs-' | append: block.id
  assign api_url  = block.settings.api_url
  assign checkout_url = block.settings.checkout_url
-%}

<div
  id="{{ block_id }}"
  class="bocs-root"
  data-api-url="{{ api_url | escape }}"
  data-checkout-url="{{ checkout_url | escape }}"
  {{ block.shopify_attributes }}
>
  <!-- Loading -->
  <div class="bocs-loading">
    <div class="bocs-spinner-wrap">
      <svg class="bocs-spinner" viewBox="0 0 50 50" xmlns="http://www.w3.org/2000/svg">
        <circle class="bocs-spinner__track" cx="25" cy="25" r="20" fill="none" stroke-width="3"/>
        <circle class="bocs-spinner__arc"   cx="25" cy="25" r="20" fill="none" stroke-width="3"
                stroke-dasharray="80 200" stroke-dashoffset="0" stroke-linecap="round"/>
      </svg>
      <p class="bocs-loading__label">Loading your subscription box…</p>
    </div>
    <div class="bocs-sk-body">
      <div class="bocs-sk bocs-sk--hero"></div>
      <div style="padding:24px">
        <div class="bocs-sk bocs-sk--title"></div>
        <div class="bocs-sk bocs-sk--text"></div>
        <div class="bocs-sk bocs-sk--text" style="width:60%"></div>
      </div>
    </div>
  </div>

  <!-- Main content -->
  <div class="bocs-content" hidden></div>

  <!-- Empty state (no BOCS from API) -->
  <div class="bocs-empty" hidden>
    <div class="bocs-empty__icon" aria-hidden="true">📦</div>
    <h3 class="bocs-empty__title">No subscription available for now</h3>
    <p class="bocs-empty__text">We don’t have any subscription boxes set up at the moment. Check back later or browse our regular products.</p>
  </div>

  <!-- Error (Ah Snap) -->
  <div class="bocs-error" hidden>
    <div class="bocs-error__icon" aria-hidden="true">😵</div>
    <h3 class="bocs-error__title">Ah snap!</h3>
    <p class="bocs-error__msg">Something went wrong loading your subscription options. Please refresh the page or try again in a few minutes.</p>
  </div>
</div>

<style>
  /* ── Reset ────────────────────────────────────────────────────────── */
  #{{ block_id }} *, #{{ block_id }} *::before, #{{ block_id }} *::after {
    box-sizing: border-box; margin: 0; padding: 0;
  }

  /* ── Root / CSS Variables (theme-friendly: override via theming or inherit) ── */
  #{{ block_id }} {
    --bg:       #ffffff;
    --card:     #ffffff;
    --hover:    rgba(0,0,0,0.06);
    --border:   rgba(0,0,0,0.12);
    --dark:     #000000;
    --text:     #000000;
    --muted:    #666666;
    --accent:   currentColor;
    --btn:      #000000;
    --btn-text: #ffffff;
    --success:  #15803d;
    --error:    #b91c1c;
    --radius:   0px;
    --shadow:   none;
    --border-w: 1px;
    font-family: var(--font-body-family, inherit);
    background: var(--bg);
    color: var(--text);
    overflow: hidden;
  }

  /* ── Spinner ──────────────────────────────────────────────────────── */
  @keyframes bocs-spin  { 100% { transform: rotate(360deg); } }
  @keyframes bocs-dash  {
    0%   { stroke-dasharray: 1 200; stroke-dashoffset: 0; }
    50%  { stroke-dasharray: 90 200; stroke-dashoffset: -35; }
    100% { stroke-dasharray: 90 200; stroke-dashoffset: -124; }
  }
  @keyframes bocs-shimmer {
    0%   { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  #{{ block_id }} .bocs-spinner-wrap {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; padding: 40px 24px 20px; gap: 14px;
  }
  #{{ block_id }} .bocs-spinner { width: 48px; height: 48px; animation: bocs-spin 2s linear infinite; }
  #{{ block_id }} .bocs-spinner__track { stroke: var(--border); }
  #{{ block_id }} .bocs-spinner__arc   { stroke: var(--btn); animation: bocs-dash 1.5s ease-in-out infinite; }
  #{{ block_id }} .bocs-loading__label { font-size: 0.8rem; color: var(--muted); font-style: italic; letter-spacing: 0.03em; }

  /* ── Skeleton ─────────────────────────────────────────────────────── */
  #{{ block_id }} .bocs-sk {
    background: linear-gradient(90deg, var(--border) 25%, var(--hover) 50%, var(--border) 75%);
    background-size: 200% 100%; animation: bocs-shimmer 1.4s infinite;
  }
  #{{ block_id }} .bocs-sk--hero  { height: 280px; width: 100%; }
  #{{ block_id }} .bocs-sk--title { height: 28px; width: 55%; border-radius: 2px; margin-bottom: 12px; }
  #{{ block_id }} .bocs-sk--text  { height: 16px; width: 80%; border-radius: 2px; margin-bottom: 8px; }

  /* ── Hero ─────────────────────────────────────────────────────────── */
  #{{ block_id }} .bocs-hero {
    width: 100%; height: clamp(180px, 30vw, 320px);
    object-fit: cover; display: block;
  }
  #{{ block_id }} .bocs-hero--placeholder {
    width: 100%; height: clamp(180px, 30vw, 320px);
    background: var(--hover); display: flex; align-items: center;
    justify-content: center; font-size: 4rem;
  }

  /* ── Intro (wine details — centre aligned) ────────────────────────── */
  #{{ block_id }} .bocs-intro {
    padding: 20px 24px; border-bottom: var(--border-w) solid var(--border);
    background: var(--card); text-align: center;
  }
  #{{ block_id }} .bocs-header { display: flex; align-items: center; justify-content: center; gap: 10px; flex-wrap: wrap; margin-bottom: 4px; }
  #{{ block_id }} .bocs-name {
    font-size: clamp(1.1rem, 3vw, 1.5rem); font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.08em; line-height: 1.15; color: var(--text);
  }
  #{{ block_id }} .bocs-badge {
    display: inline-flex; align-items: center; gap: 4px; padding: 3px 9px;
    font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em;
    border-radius: var(--radius); background: var(--hover); color: var(--success); white-space: nowrap;
  }
  #{{ block_id }} .bocs-tagline { font-size: 0.82rem; color: var(--accent); font-style: italic; margin-bottom: 4px; }
  #{{ block_id }} .bocs-desc { font-size: 0.85rem; color: var(--muted); line-height: 1.6; font-style: italic; }

  /* ── Value Propositions (theme button/primary color, theme button text) ── */
  /* Value prop: same background as next button, white text */
  #{{ block_id }} .bocs-value-props {
    display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; padding: 12px 24px;
    background: var(--btn); border-bottom: var(--border-w) solid var(--border);
  }
  #{{ block_id }} .bocs-value-prop {
    font-size: 0.68rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em;
    color: #ffffff; display: flex; align-items: center; gap: 5px;
  }
  #{{ block_id }} .bocs-value-prop::before { content: '✓'; color: #ffffff; opacity: 0.9; }

  /* ── Progress Bar (wizard) — more spacing between steps ───────────── */
  #{{ block_id }} .widget-progress-bar {
    display: flex; align-items: center; justify-content: center;
    margin: 20px 24px 0; padding: 20px 28px; background: var(--card);
    border: var(--border-w) solid var(--border); border-radius: var(--radius);
    gap: 5px;
  }
  @media (min-width: 768px) {
    #{{ block_id }} .widget-progress-bar { gap: 20px; }
  }
  #{{ block_id }} .widget-progress-bar .bocs-progress__step {
    display: flex; flex-direction: column; align-items: center; gap: 6px; position: relative;
    min-width: 88px;
  }
  #{{ block_id }} .widget-progress-bar .step-dot {
    width: 30px; height: 30px; border-radius: 50%;
    border: 2px solid var(--border); display: flex; align-items: center; justify-content: center;
    font-size: 0.72rem; font-weight: 700; background: var(--card); color: var(--muted);
    transition: all 0.3s ease; cursor: default; user-select: none;
  }
  #{{ block_id }} .widget-progress-bar .step-dot.active {
    background: var(--btn); border-color: var(--btn); color: var(--btn-text);
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }
  #{{ block_id }} .widget-progress-bar .step-dot.done {
    background: var(--btn); border-color: var(--btn); color: var(--btn-text); opacity: 0.7;
  }
  #{{ block_id }} .widget-progress-bar .bocs-progress__label {
    font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.07em; color: var(--muted);
    white-space: nowrap; line-height: 1;
  }
  #{{ block_id }} .widget-progress-bar .bocs-progress__label.active { color: var(--btn); font-weight: 700; }
  #{{ block_id }} .widget-progress-bar .bocs-progress__summary {
    font-size: 0.55rem; color: var(--muted); font-style: italic; white-space: nowrap; max-width: 80px;
    overflow: hidden; text-overflow: ellipsis; text-align: center;
  }
  #{{ block_id }} .widget-progress-bar .step-line {
    flex: 1; height: 1px; background: var(--border); margin: 0 32px;
    margin-bottom: 18px; min-width: 48px; max-width: 120px; transition: background 0.3s ease;
  }
  #{{ block_id }} .widget-progress-bar .step-line.done { background: var(--btn); opacity: 0.7; }

  /* Progress — dots variant */
  #{{ block_id }} .widget-progress-bar.is-dots .bocs-progress__step { gap: 0; }
  #{{ block_id }} .widget-progress-bar.is-dots .step-dot {
    width: 10px; height: 10px; border-radius: 50%; border: none; font-size: 0;
    background: var(--border);
  }
  #{{ block_id }} .widget-progress-bar.is-dots .step-dot.active { background: var(--btn); width: 24px; border-radius: 5px; }
  #{{ block_id }} .widget-progress-bar.is-dots .step-dot.done { background: var(--btn); opacity: 0.5; }
  #{{ block_id }} .widget-progress-bar.is-dots .step-line { margin: 0 28px; margin-bottom: 0; }
  #{{ block_id }} .widget-progress-bar.is-dots .bocs-progress__label { display: none; }

  /* Mobile: stepper shows only current step (one by one) */
  @media (max-width: 767px) {
    #{{ block_id }} .widget-progress-bar .bocs-progress__step { display: none !important; }
    #{{ block_id }} .widget-progress-bar .bocs-progress__step.active { display: flex !important; }
    #{{ block_id }} .widget-progress-bar .step-line { display: none !important; }
  }

  /* Progress — fraction */
  #{{ block_id }} .bocs-progress-fraction {
    padding: 10px 24px; text-align: center; font-size: 0.75rem;
    color: var(--muted); font-style: italic; border-bottom: var(--border-w) solid var(--border);
    background: var(--card);
  }
  #{{ block_id }} .bocs-progress-fraction strong { color: var(--text); font-style: normal; }

  /* ── Section ──────────────────────────────────────────────────────── */
  #{{ block_id }} .bocs-section {
    padding: 24px; border-bottom: var(--border-w) solid var(--border); background: var(--bg);
  }

  /* ── Step header ──────────────────────────────────────────────────── */
  #{{ block_id }} .bocs-step-header { margin-bottom: 20px; }
  #{{ block_id }} .bocs-step-header__img {
    width: 100%; height: clamp(160px, 20vw, 240px); object-fit: cover; display: block;
    margin-bottom: 16px; border-radius: var(--radius);
  }
  #{{ block_id }} .bocs-step-header h3 {
    font-size: clamp(0.9rem, 2.5vw, 1.05rem); font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.06em; color: var(--text); margin-bottom: 4px;
  }
  #{{ block_id }} .bocs-step-header p { font-size: 0.8rem; color: var(--muted); font-style: italic; }

  /* ── Transitions ──────────────────────────────────────────────────── */
  #{{ block_id }} .bocs-step-panel { overflow: hidden; }

  @keyframes bocs-slide-from-right { from { transform: translateX(30px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @keyframes bocs-slide-from-left  { from { transform: translateX(-30px); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
  @keyframes bocs-slide-from-bottom { from { transform: translateY(20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  @keyframes bocs-slide-from-top   { from { transform: translateY(-20px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  @keyframes bocs-fade-in          { from { opacity: 0; } to { opacity: 1; } }

  #{{ block_id }} .bocs-trans--slide-h-forward  { animation: bocs-slide-from-right var(--trans-speed, 0.3s) ease; }
  #{{ block_id }} .bocs-trans--slide-h-backward { animation: bocs-slide-from-left var(--trans-speed, 0.3s) ease; }
  #{{ block_id }} .bocs-trans--slide-v-forward  { animation: bocs-slide-from-bottom var(--trans-speed, 0.3s) ease; }
  #{{ block_id }} .bocs-trans--slide-v-backward { animation: bocs-slide-from-top var(--trans-speed, 0.3s) ease; }
  #{{ block_id }} .bocs-trans--fade             { animation: bocs-fade-in var(--trans-speed, 0.3s) ease; }

  /* ── Pack grid ────────────────────────────────────────────────────── */
  #{{ block_id }} .bocs-pack-grid {
    display: grid; grid-template-columns: 1fr; gap: 14px; margin-bottom: 20px;
  }
  @media (min-width: 768px) {
    #{{ block_id }} .bocs-pack-grid { grid-template-columns: repeat(2, 1fr); }
  }
  #{{ block_id }} .bocs-pack-card {
    border: var(--border-w) solid var(--border); cursor: pointer;
    transition: all 0.25s ease; background: var(--card);
    position: relative; overflow: hidden; border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
  #{{ block_id }} .bocs-pack-card:hover { border-color: var(--dark); }
  #{{ block_id }} .bocs-pack-card.is-selected { border-color: var(--btn); border-width: 2px; }
  #{{ block_id }} .bocs-pack-card__img-wrap { width: 100%; aspect-ratio: 4/3; overflow: hidden; position: relative; }
  #{{ block_id }} .bocs-pack-card__savings--overlay {
    position: absolute; top: 8px; right: 8px;
    padding: 4px 10px; background: var(--btn); color: #ffffff;
    font-size: 0.65rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.04em;
    border-radius: var(--radius); z-index: 1;
  }
  #{{ block_id }} .bocs-pack-card__img-wrap img {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.35s ease;
  }
  #{{ block_id }} .bocs-pack-card:hover .bocs-pack-card__img-wrap img { transform: scale(1.06); }
  #{{ block_id }} .bocs-pack-card__img-placeholder {
    background: var(--hover); display: flex; align-items: center;
    justify-content: center; font-size: 2.5rem;
  }
  #{{ block_id }} .bocs-pack-card__body { padding: 12px; }
  #{{ block_id }} .bocs-pack-card__qty-badge {
    font-size: 0.58rem; text-transform: uppercase; letter-spacing: 0.07em;
    color: var(--accent); font-weight: 700; margin-bottom: 2px;
  }
  #{{ block_id }} .bocs-pack-card__name {
    font-size: 0.82rem; font-weight: 700; color: var(--text); margin-bottom: 4px;
  }
  #{{ block_id }} .bocs-pack-card__desc {
    font-size: 0.68rem; color: var(--muted); font-style: italic;
    line-height: 1.4; margin-bottom: 6px;
  }
  #{{ block_id }} .bocs-pack-card__savings {
    font-size: 0.65rem; color: var(--accent); font-weight: 600;
  }
  #{{ block_id }} .bocs-pack-card__savings--overlay {
    color: #ffffff !important;
  }
  #{{ block_id }} .bocs-pack-card__check {
    position: absolute; top: 8px; right: 8px; width: 22px; height: 22px;
    border-radius: 50%; background: var(--btn); color: white;
    font-size: 0.65rem; display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.2s; box-shadow: 0 2px 6px rgba(0,0,0,0.2);
  }
  #{{ block_id }} .bocs-pack-card.is-selected .bocs-pack-card__check { opacity: 1; }

  /* ── Frequency list (card grid like product cards) ────────────────── */
  #{{ block_id }} .bocs-freq-list {
    display: grid; grid-template-columns: 1fr; gap: 14px; margin-bottom: 20px;
  }
  @media (min-width: 768px) {
    #{{ block_id }} .bocs-freq-list { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 992px) {
    #{{ block_id }} .bocs-freq-list { grid-template-columns: repeat(3, 1fr); }
  }
  #{{ block_id }} .bocs-freq-card {
    border: var(--border-w) solid var(--border); cursor: pointer;
    transition: all 0.25s ease; overflow: hidden; background: var(--card);
    border-radius: var(--radius); box-shadow: var(--shadow);
    position: relative;
  }
  #{{ block_id }} .bocs-freq-card:hover { border-color: var(--dark); }
  #{{ block_id }} .bocs-freq-card.is-selected { border-color: var(--btn); border-width: 2px; }
  #{{ block_id }} .bocs-freq-card__img-wrap { width: 100%; aspect-ratio: 4/3; overflow: hidden; position: relative; }
  #{{ block_id }} .bocs-freq-card__img-placeholder {
    background: var(--hover); display: flex; align-items: center; justify-content: center; font-size: 2rem;
  }
  #{{ block_id }} .bocs-freq-card__disc--overlay {
    position: absolute; top: 8px; right: 8px;
    display: inline-block; padding: 4px 10px; background: var(--btn); color: var(--btn-text);
    font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    border-radius: var(--radius); z-index: 1;
  }
  #{{ block_id }} .bocs-freq-card__img-wrap img {
    width: 100%; height: 100%; object-fit: cover; display: block; transition: transform 0.35s ease;
  }
  #{{ block_id }} .bocs-freq-card:hover .bocs-freq-card__img-wrap img { transform: scale(1.06); }
  #{{ block_id }} .bocs-freq-card__body { padding: 12px; }
  #{{ block_id }} .bocs-freq-card__row {
    display: flex; align-items: flex-start; justify-content: space-between; gap: 8px; margin-bottom: 8px;
  }
  #{{ block_id }} .bocs-freq-card__interval {
    font-size: 0.82rem; font-weight: 700; color: var(--text);
    text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 2px;
  }
  #{{ block_id }} .bocs-freq-card__tagline { font-size: 0.7rem; color: var(--muted); font-style: italic; }
  #{{ block_id }} .bocs-freq-card__badges { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
  #{{ block_id }} .bocs-freq-card__disc {
    display: inline-block; padding: 2px 8px; background: var(--btn); color: var(--btn-text);
    font-size: 0.62rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    border-radius: var(--radius);
  }
  #{{ block_id }} .bocs-freq-card__best {
    display: inline-block; padding: 2px 8px; background: var(--hover); color: var(--text);
    font-size: 0.6rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.06em;
    border-radius: var(--radius);
  }
  #{{ block_id }} .bocs-freq-card__footer {
    display: flex; align-items: center; justify-content: flex-end;
    font-size: 0.68rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.05em; color: var(--muted);
  }
  #{{ block_id }} .bocs-freq-card.is-selected .bocs-freq-card__footer { color: var(--btn); }

  /* ── Products grid ────────────────────────────────────────────────── */
  #{{ block_id }} .bocs-products-grid {
    display: grid; grid-template-columns: 1fr; gap: 12px; margin-bottom: 20px;
  }
  @media (min-width: 768px) {
    #{{ block_id }} .bocs-products-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 992px) {
    #{{ block_id }} .bocs-products-grid { grid-template-columns: repeat(3, 1fr); }
  }
  #{{ block_id }} .bocs-product-card {
    border: var(--border-w) solid var(--border); background: var(--card);
    overflow: hidden; transition: border-color 0.2s; border-radius: var(--radius);
    box-shadow: var(--shadow);
  }
  #{{ block_id }} .bocs-product-card.is-oos { opacity: 0.55; }
  #{{ block_id }} .bocs-product-card.is-selected { border-color: var(--btn); border-width: 2px; }
  #{{ block_id }} .bocs-product-card__img-wrap {
    width: 100%; aspect-ratio: 1; overflow: hidden; background: var(--hover); position: relative;
  }
  #{{ block_id }} .bocs-product-card__img-wrap img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  #{{ block_id }} .bocs-product-card__img-overlay {
    position: absolute; inset: 0; display: flex; flex-direction: column;
    justify-content: space-between; padding: 8px; pointer-events: none; z-index: 1;
  }
  #{{ block_id }} .bocs-product-card__img-overlay .bocs-product-card__tags {
    margin-bottom: 0; flex-wrap: wrap;
  }
  #{{ block_id }} .bocs-product-card__img-overlay .bocs-product-card__tag {
    background: rgba(0,0,0,0.6); color: #fff;
  }
  #{{ block_id }} .bocs-product-card__oos--overlay {
    align-self: flex-start; padding: 4px 10px; background: var(--error, #b91c1c);
    color: #ffffff !important; font-size: 0.62rem; font-weight: 600;
    text-transform: uppercase; letter-spacing: 0.04em; border-radius: var(--radius);
    z-index: 2; display: inline-block;
  }
  #{{ block_id }} .bocs-product-card__img-overlay .bocs-product-card__img-overlay-bottom {
