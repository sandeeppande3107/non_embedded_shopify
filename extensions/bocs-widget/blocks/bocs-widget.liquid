  function applyTheme(b) {
    var colors = (getTheming()).colors || {};
    if (colors.primary)    root.style.setProperty('--btn', colors.primary);
    if (colors.accent)     root.style.setProperty('--accent', colors.accent);
    if (colors.text)       root.style.setProperty('--text', colors.text);
    if (colors.background) root.style.setProperty('--bg', colors.background);

    var comp = getTheming().components || {};
    if (comp.borderRadius) root.style.setProperty('--radius', comp.borderRadius);
    if (comp.borderWeight) root.style.setProperty('--border-w', comp.borderWeight);
    var shadowMap = { 'none':'none', 'subtle':'0 1px 4px rgba(0,0,0,0.08)', 'medium':'0 2px 8px rgba(0,0,0,0.12)', 'strong':'0 4px 16px rgba(0,0,0,0.18)' };
    if (comp.cardShadow && shadowMap[comp.cardShadow]) root.style.setProperty('--shadow', shadowMap[comp.cardShadow]);

    var speed = resolveTransSpeed();
    root.style.setProperty('--trans-speed', (speed / 1000).toFixed(2) + 's');

    var typo = getTheming().typography || {};
    if (typo.headingWeight) {
      root.querySelectorAll('.bocs-name,.bocs-step-header h3,.bocs-pack-card__name,.bocs-freq-card__interval')
          .forEach(function(el){ el.style.fontWeight = typo.headingWeight; });
    }
  }

  // ── Dynamic Style Injection ────────────────────────────────────────
  function injectDynamicStyles(b) {
    // External CSS
    var tm = getTheming();
    if (tm.customStyleMode === 'external' && tm.customCssUrl) {
      var linkId = blockId + '-ext';
      if (!document.getElementById(linkId)) {
        var lnk = document.createElement('link');
        lnk.id = linkId; lnk.rel = 'stylesheet'; lnk.href = tm.customCssUrl;
        document.head.appendChild(lnk);
      }
    }

    // Inline CSS
    if (tm.customStyleMode === 'inline' && tm.customCss) {
      var inlineId = blockId + '-inline';
      var inlineEl = document.getElementById(inlineId) || document.createElement('style');
      inlineEl.id = inlineId; inlineEl.textContent = tm.customCss;
      if (!document.getElementById(inlineId)) document.head.appendChild(inlineEl);
    }

    // Scoped dynamic CSS (progress bar + step CSS + card CSS)
    // Append after block's <style> so overrides win (block style is sibling after root)
    var sid = blockId + '-dyn';
    var styleEl = document.getElementById(sid);
    if (!styleEl) {
      styleEl = document.createElement('style');
      styleEl.id = sid;
      if (root.parentNode) root.parentNode.appendChild(styleEl);
      else document.head.appendChild(styleEl);
    }

    var css = '';

    // Progress bar CSS (scoped by replacing .widget-progress-bar with #id .widget-progress-bar)
    var pbCss = (getFlow()).progressBarCss || '';
    if (pbCss.trim()) {
      css += pbCss.replace(/(\.widget-progress-bar)/g, '#' + blockId + ' $1') + '\n';
    }

    // Step content CSS: full rules (scope with #blockId) or declarations (wrap in step selector)
    var sc = (getFlow()).stepContent || {};
    var scopeId = '#' + blockId;
    [1,2,3,4].forEach(function(n) {
      var step = sc[n] || sc[String(n)] || {};
      var stepCss = step.css && step.css.trim();
      if (!stepCss || /^\s*\/\*/.test(stepCss)) return;
      if (stepCss.indexOf('{') !== -1) {
        css += scopeCssRules(stepCss, scopeId) + '\n';
      } else {
        css += scopeId + ' .bocs-step[data-step="' + n + '"] { ' + stepCss + ' }\n';
      }
    });

    // Frequency card CSS: full rules (scope with #blockId) or declarations (wrap in card selector)
    (b.packSizes || []).forEach(function(pack) {
      (pack.frequencies || []).forEach(function(freq) {
        var cardCss = freq.cardCss && freq.cardCss.trim();
        if (!cardCss) return;
        if (cardCss.indexOf('{') !== -1) {
          css += scopeCssRules(cardCss, scopeId) + '\n';
        } else {
          css += scopeId + ' .bocs-freq-card[data-freq-id="' + freq.id + '"] { ' + cardCss + ' }\n';
        }
      });
    });

    styleEl.textContent = css;
  }

  // ── Hero section ───────────────────────────────────────────────────
  function renderHero(b) {
    var imgUrl  = (b.basics || {}).imageUrl;
    var tagline = (b.basics || {}).tagline;
    var flow    = getFlow();
    var vps     = flow.valuePropositions || [];
    var html    = '';

    if (imgUrl) {
      html += '<img class="bocs-hero" src="' + esc(imgUrl) + '" alt="' + esc(b.name) + '" loading="lazy">';
    } else {
      html += '<div class="bocs-hero--placeholder">📦</div>';
    }

    html += '<div class="bocs-intro">';
    html += '<div class="bocs-header"><h2 class="bocs-name">' + esc(b.name) + '</h2>'
          + '<span class="bocs-badge">● Active</span></div>';
    if (tagline) html += '<p class="bocs-tagline">' + esc(tagline) + '</p>';
    if (b.description) html += '<p class="bocs-desc">' + esc(b.description) + '</p>';
    html += '</div>';

    if (vps.length) {
      html += '<div class="bocs-value-props">';
      vps.forEach(function(v) { if (v) html += '<span class="bocs-value-prop">' + esc(v) + '</span>'; });
      html += '</div>';
    }

    return html;
  }

  // ── Progress indicator ─────────────────────────────────────────────
  function renderProgress(b) {
    var flow      = getFlow();
    var indicator = flow.progressIndicator || 'step-bar-labels';
    var opts      = flow.progressBarOptions || {};
    var sc        = flow.stepContent || {};
    var pack      = b.packSizes[state.packIndex];
    var freq      = pack && pack.frequencies[state.freqIndex];

    if (indicator === 'none') return '';

    if (indicator === 'fraction') {
      return '<div class="bocs-progress-fraction">Step <strong>' + state.step + '</strong> of 3</div>';
    }

    var isDots   = indicator === 'dots';
    var labels   = [
      (sc['1'] || {}).progressLabel || 'Pack Size',
      (sc['2'] || {}).progressLabel || 'Frequency',
      (sc['3'] || {}).progressLabel || 'Products'
    ];
    var summaries = ['', '', ''];
    if (opts.showSummaryValues) {
      summaries[0] = pack ? pack.displayLabel : '';
      summaries[1] = freq ? freq.interval : '';
      if (isFixed() && pack) summaries[2] = pack.quantity + ' items';
    }

    var html = '<div class="widget-progress-bar' + (isDots ? ' is-dots' : '') + '">';
    for (var i = 0; i < 3; i++) {
      var cls = i + 1 < state.step ? 'done' : (i + 1 === state.step ? 'active' : '');
      html += '<div class="bocs-progress__step' + (cls === 'active' ? ' active' : '') + '">'
        + '<div class="step-dot ' + cls + '">' + (i + 1 < state.step ? '✓' : (isDots ? '' : String(i + 1))) + '</div>';
      if (!isDots && opts.showStepLabels !== false) {
        html += '<span class="bocs-progress__label' + (cls === 'active' ? ' active' : '') + '">' + esc(labels[i]) + '</span>';
      }
      if (!isDots && summaries[i]) {
        html += '<span class="bocs-progress__summary">' + esc(summaries[i]) + '</span>';
      }
      html += '</div>';
      if (i < 2) html += '<div class="step-line' + (i + 1 < state.step ? ' done' : '') + '"></div>';
    }
    html += '</div>';
    return html;
  }

  // ── Step 1: Pack selector ──────────────────────────────────────────
  function renderStep1(b) {
    var sc   = (getFlow().stepContent || {})['1'] || {};
    var ps   = getBlockSettings().packSelector || {};
    var html = '<div class="bocs-section bocs-step step--pack-size" data-step="1">';

    if (sc.imageUrl) html += '<img class="bocs-step-header__img" src="' + esc(sc.imageUrl) + '" alt="" loading="lazy">';
    html += '<div class="bocs-step-header"><h3>' + esc(sc.headingOverride || 'Choose Your Pack') + '</h3>'
          + (sc.description ? '<p>' + esc(sc.description) + '</p>' : '') + '</div>';

    html += '<div class="bocs-pack-grid">';
    b.packSizes.forEach(function(pack, i) {
      var isSel  = state.packIndex === i;
      var maxDis = maxDiscount(pack.frequencies);
      html += '<div class="bocs-pack-card' + (isSel ? ' is-selected' : '') + '" data-pack-idx="' + i + '">';

      if (ps.showPackImage !== false && pack.packImageUrl) {
        html += '<div class="bocs-pack-card__img-wrap">';
        html += '<img src="' + esc(pack.packImageUrl) + '" alt="' + esc(pack.displayLabel) + '" loading="lazy">';
        if (ps.showPriceRange !== false && maxDis > 0) {
          html += '<span class="bocs-pack-card__savings bocs-pack-card__savings--overlay">Save up to ' + maxDis + '% off</span>';
        }
        html += '</div>';
      } else {
        html += '<div class="bocs-pack-card__img-wrap bocs-pack-card__img-placeholder">📦</div>';
      }

      html += '<div class="bocs-pack-card__body">'
        + '<div class="bocs-pack-card__qty-badge">' + esc(pack.quantity) + ' bottles</div>'
        + '<h4 class="bocs-pack-card__name">' + esc(pack.displayLabel) + '</h4>';
      if (ps.showPackDescription !== false && pack.packDescription) {
        html += '<p class="bocs-pack-card__desc">' + esc(pack.packDescription) + '</p>';
      }
      if (ps.showPriceRange !== false && maxDis > 0 && !(pack.packImageUrl && ps.showPackImage !== false)) {
        html += '<p class="bocs-pack-card__savings">Save up to ' + maxDis + '% off</p>';
      }
      html += '</div>';
      html += '<div class="bocs-pack-card__check">✓</div>';
      html += '</div>';
    });
    html += '</div>';

    if (isWizard()) {
      html += '<div class="bocs-step-nav"><span></span>'
        + '<button class="bocs-btn bocs-btn--next" data-action="next">Next ' + chevRight() + '</button></div>';
    }

    html += '</div>';
    return html;
  }

  // ── Step 2: Frequency picker ───────────────────────────────────────
  function renderStep2(b) {
    var pack = b.packSizes[state.packIndex];
    if (!pack) return '';
    var sc   = (getFlow().stepContent || {})['2'] || {};
    var fp   = getBlockSettings().frequencyPicker || {};
    var bvIdx = bestValueIndex(pack.frequencies);

    var html = '<div class="bocs-section bocs-step step--frequency" data-step="2">';
    if (sc.imageUrl) html += '<img class="bocs-step-header__img" src="' + esc(sc.imageUrl) + '" alt="" loading="lazy">';
    html += '<div class="bocs-step-header"><h3>' + esc(sc.headingOverride || 'Choose Delivery Frequency') + '</h3>'
          + (sc.description ? '<p>' + esc(sc.description) + '</p>' : '') + '</div>';

    html += '<div class="bocs-freq-list">';
    pack.frequencies.forEach(function(freq, i) {
      var isSel = state.freqIndex === i;
      var isBV  = (i === bvIdx) && (parseFloat(freq.discount) || 0) > 0;
      var freqSlug = (freq.name || '').toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9-]/g, '');
      var freqCardClasses = 'bocs-freq-card' + (freqSlug ? ' freq-card--' + freqSlug : '') + (isSel ? ' is-selected' : '');
      html += '<div class="' + freqCardClasses + '"'
        + ' data-freq-idx="' + i + '" data-freq-id="' + esc(freq.id) + '">';

      if (freq.cardImageUrl) {
        html += '<div class="bocs-freq-card__img-wrap">';
        html += '<img src="' + esc(freq.cardImageUrl) + '" alt="' + esc(freq.interval) + '" loading="lazy">';
        if (fp.showDiscountPct !== false && parseFloat(freq.discount) > 0) {
          html += '<span class="bocs-freq-card__disc bocs-freq-card__disc--overlay">Save ' + esc(freq.discount) + '%</span>';
        }
        html += '</div>';
      } else {
        html += '<div class="bocs-freq-card__img-wrap bocs-freq-card__img-placeholder">📅</div>';
      }
      html += '<div class="bocs-freq-card__body"><div class="bocs-freq-card__row"><div>'
        + '<p class="bocs-freq-card__interval">' + esc(freq.interval) + '</p>'
        + (freq.cardTagline ? '<p class="bocs-freq-card__tagline">' + esc(freq.cardTagline) + '</p>' : '')
        + '</div><div class="bocs-freq-card__badges">';
      if (fp.showDiscountPct !== false && parseFloat(freq.discount) > 0 && !freq.cardImageUrl) {
        html += '<span class="bocs-freq-card__disc">Save ' + esc(freq.discount) + '%</span>';
      }
      if (isBV && fp.highlightBadge !== 'none') {
        var badgeLabel = fp.highlightBadge === 'most-popular' ? 'Most Popular'
          : fp.highlightBadge === 'recommended' ? 'Recommended' : 'Best Value';
        html += '<span class="bocs-freq-card__best">' + badgeLabel + '</span>';
      }
      html += '</div></div>';
      html += '<div class="bocs-freq-card__footer">' + (isSel ? '✓ Selected' : 'Select') + '</div>';
      html += '</div></div>';
    });
    html += '</div>';

    if (isWizard()) {
      html += '<div class="bocs-step-nav">'
        + '<button class="bocs-btn bocs-btn--back" data-action="back">' + chevLeft() + ' Back</button>'
        + '<button class="bocs-btn bocs-btn--next" data-action="next">Next ' + chevRight() + '</button></div>';
    }

    html += '</div>';
    return html;
  }

  // ── Step 3: Products ───────────────────────────────────────────────
  function renderStep3(b) {
    var pack  = b.packSizes[state.packIndex];
    var freq  = pack && pack.frequencies[state.freqIndex];
    if (!pack) return '';
    var sc    = (getFlow().stepContent || {})['3'] || {};
    var pb    = getBlockSettings().productBrowser || {};
    var os    = getBlockSettings().orderSummary   || {};
    var fixed = isFixed();

    var html = '<div class="bocs-section bocs-step step--products" data-step="3">';
    if (sc.imageUrl) html += '<img class="bocs-step-header__img" src="' + esc(sc.imageUrl) + '" alt="" loading="lazy">';

    var heading = sc.headingOverride || (fixed ? 'Your Selection' : 'Choose Your Items');
    html += '<div class="bocs-step-header"><h3>' + esc(heading) + '</h3>'
          + (sc.description ? '<p>' + esc(sc.description) + '</p>' : '');

    if (!fixed) {
      var totalSel = totalSelectedQty(state.selectedProducts);
      var maxQty   = pack.max;
      html += '<div class="bocs-selection-counter' + (totalSel === maxQty ? ' is-complete' : '') + '">'
        + '<span>' + totalSel + ' / ' + maxQty + ' selected</span>'
        + (totalSel < maxQty
            ? '<span class="bocs-counter-hint">Choose ' + (maxQty - totalSel) + ' more</span>'
            : '<span class="bocs-counter-done">Ready! ✓</span>')
        + '</div>';
    }
    html += '</div>';

    html += '<div class="bocs-products-grid">';
    (pack.products || []).forEach(function(p) {
      var qty = fixed ? (p.quantity || 1) : (state.selectedProducts[p.id] || 0);
      html += '<div class="bocs-product-card' + (!p.inStock ? ' is-oos' : '') + (qty > 0 && !fixed ? ' is-selected' : '') + '">';

      if (p.imageUrl) {
        html += '<div class="bocs-product-card__img-wrap">';
        html += '<img src="' + esc(p.imageUrl) + '" alt="' + esc(p.name) + '" loading="lazy">';
        html += '<div class="bocs-product-card__img-overlay">';
        html += '<div class="bocs-product-card__img-overlay-top">';
        if (pb.showTags !== false && p.tags && Array.isArray(p.tags) && p.tags.length) {
          html += '<div class="bocs-product-card__tags">';
          p.tags.forEach(function(t) { html += '<span class="bocs-product-card__tag">' + esc(t) + '</span>'; });
          html += '</div>';
        }
        html += '</div>';
        html += '<div class="bocs-product-card__img-overlay-bottom">';
        if (pb.showStock !== false && !p.inStock) {
          html += '<span class="bocs-product-card__oos bocs-product-card__oos--overlay">Out of stock</span>';
        }
        html += '</div></div></div>';
      } else {
        html += '<div class="bocs-product-card__img-wrap bocs-product-card__img-placeholder">📦';
        if (pb.showStock !== false && !p.inStock) {
          html += '<span class="bocs-product-card__oos bocs-product-card__oos--overlay">Out of stock</span>';
        }
        html += '</div>';
      }

      html += '<div class="bocs-product-card__body"><h5 class="bocs-product-card__name">' + esc(p.name) + '</h5>';
      if (!p.imageUrl && pb.showTags !== false && p.tags && Array.isArray(p.tags) && p.tags.length) {
        html += '<div class="bocs-product-card__tags">';
        p.tags.forEach(function(t) { html += '<span class="bocs-product-card__tag">' + esc(t) + '</span>'; });
        html += '</div>';
      }
      if (pb.showPrice !== false) {
        var label = p.price > 0 ? fmt(p.price) : 'Free';
        if (pb.showDiscount !== false && freq && parseFloat(freq.discount) > 0 && p.price > 0) {
          var discPrice = p.price * (1 - parseFloat(freq.discount) / 100);
          label = '<s style="opacity:.5">' + fmt(p.price) + '</s> ' + fmt(discPrice);
        }
        html += '<p class="bocs-product-card__price">' + label + '</p>';
      }
      if (fixed) {
        html += '<div class="bocs-product-card__fixed-qty">Qty: ' + esc(String(qty)) + '</div>';
      } else {
        html += '<div class="bocs-qty-ctrl">'
          + '<button class="bocs-qty-ctrl__btn" data-action="qty-dec" data-pid="' + esc(p.id) + '"' + (qty <= 0 ? ' disabled' : '') + '>−</button>'
          + '<span class="bocs-qty-ctrl__val">' + qty + '</span>'
          + '<button class="bocs-qty-ctrl__btn" data-action="qty-inc" data-pid="' + esc(p.id) + '"' + (!p.inStock || totalSelectedQty(state.selectedProducts) >= pack.max ? ' disabled' : '') + '>+</button>'
          + '</div>';
      }
      html += '</div></div>';
    });
    html += '</div>';

    // Order summary removed for now

    // Step nav / subscribe
    var canSub = canSubscribe(b);
    var ctaText = (freq && freq.ctaText) || (os.ctaButtonText) || 'Subscribe Now';

    if (isWizard()) {
      html += '<div class="bocs-step-nav">'
        + '<button class="bocs-btn bocs-btn--back" data-action="back">' + chevLeft() + ' Back</button>'
        + '<button class="bocs-subscribe" data-action="subscribe"' + (canSub ? '' : ' disabled') + '>'
        + esc(ctaText) + ' ›</button></div>';
    }

    html += '</div>';
    return html;
  }

  // ── Sticky action bar ──────────────────────────────────────────────
  function renderActionBar(b) {
    var pack   = b.packSizes[state.packIndex];
    var freq   = pack && pack.frequencies[state.freqIndex];
    var os     = getBlockSettings().orderSummary || {};
    var canSub = canSubscribe(b);

    var info = '';
    if (pack) info += '<strong>' + esc(pack.displayLabel) + '</strong>';
    if (freq) info += ' · ' + esc(freq.interval);
    if (!info) info = '<em>Select your pack to get started</em>';

    var html = '<div class="bocs-bar"><div class="bocs-bar__info">' + info + '</div>';

    if (!isWizard()) {
      var ctaText = (freq && freq.ctaText) || (os.ctaButtonText) || 'Subscribe Now';
      html += '<button class="bocs-subscribe" data-action="subscribe"' + (canSub ? '' : ' disabled') + '>'
        + esc(ctaText) + ' ›</button>';
    }

    html += '</div><div class="bocs-toast"></div>';
    return html;
  }

  // ── canSubscribe check ─────────────────────────────────────────────
  function canSubscribe(b) {
    if (state.packIndex < 0 || state.freqIndex < 0) return false;
    var pack = b.packSizes[state.packIndex];
    if (!pack) return false;
    if (!isFixed()) {
      var total = totalSelectedQty(state.selectedProducts);
      return total >= pack.min && total <= pack.max;
    }
    return true;
  }

  // ── Full render ────────────────────────────────────────────────────
  function render(transClass) {
    var b    = bocs;
    var html = renderHero(b);

    if (isWizard()) {
      html += renderProgress(b);
      html += '<div class="bocs-step-panel' + (transClass ? ' ' + transClass : '') + '">';
      if (state.step === 1) html += renderStep1(b);
      else if (state.step === 2) html += renderStep2(b);
      else if (state.step === 3) html += renderStep3(b);
      html += '</div>';
    } else {
      // Single layout — all sections on one page
      html += renderStep1(b);
      html += renderStep2(b);
      html += renderStep3(b);
    }

    html += renderActionBar(b);

    contentEl.innerHTML = html;
    contentEl.hidden    = false;

    attachEvents();
    applyTheme(b);
  }

  // ── Navigate wizard step ───────────────────────────────────────────
  function goToStep(newStep, forward) {
    var transition = (getFlow().transition || 'fade');
    var speed      = resolveTransSpeed();

    if (transition === 'instant') {
      state.step = newStep; state.navigatingForward = forward;
      render();
      return;
    }

    var dir = forward ? 'forward' : 'backward';
    var cls = transition === 'slide-horizontal' ? 'bocs-trans--slide-h-' + dir
            : transition === 'slide-vertical'   ? 'bocs-trans--slide-v-' + dir
            : 'bocs-trans--fade';

    // Brief exit fade on panel, then re-render with enter animation
    var panel = contentEl.querySelector('.bocs-step-panel');
    if (panel) {
      panel.style.transition = 'opacity ' + (speed * 0.3 / 1000) + 's ease';
      panel.style.opacity    = '0';
      setTimeout(function() {
        state.step = newStep; state.navigatingForward = forward;
        render(cls);
      }, speed * 0.3);
    } else {
      state.step = newStep; state.navigatingForward = forward;
      render(cls);
    }
  }

  // ── Event binding ──────────────────────────────────────────────────
  function attachEvents() {
    // Pack card click
    contentEl.querySelectorAll('.bocs-pack-card').forEach(function(el) {
      el.addEventListener('click', function() {
        var idx = parseInt(el.dataset.packIdx, 10);
        if (idx !== state.packIndex) {
          state.packIndex = idx;
          state.freqIndex = isFixed() ? 0 : bestValueIndex(bocs.packSizes[idx].frequencies || []);
          state.selectedProducts = {};
        }
        render(isWizard() ? null : null);
      });
    });

    // Frequency card click
    contentEl.querySelectorAll('.bocs-freq-card').forEach(function(el) {
      el.addEventListener('click', function() {
        state.freqIndex = parseInt(el.dataset.freqIdx, 10);
        render();
      });
    });

    // Qty increment
    contentEl.querySelectorAll('[data-action="qty-inc"]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.stopPropagation();
        var pid  = el.dataset.pid;
        var pack = bocs.packSizes[state.packIndex];
        if (pack && totalSelectedQty(state.selectedProducts) < pack.max) {
          state.selectedProducts[pid] = (state.selectedProducts[pid] || 0) + 1;
          render();
        }
      });
    });

    // Qty decrement
    contentEl.querySelectorAll('[data-action="qty-dec"]').forEach(function(el) {
      el.addEventListener('click', function(e) {
        e.stopPropagation();
        var pid = el.dataset.pid;
        if ((state.selectedProducts[pid] || 0) > 0) {
          state.selectedProducts[pid]--;
          render();
        }
      });
    });

    // Wizard Next button
    var nextBtn = contentEl.querySelector('[data-action="next"]');
    if (nextBtn) {
      nextBtn.addEventListener('click', function() {
        if (state.step < 3) goToStep(state.step + 1, true);
      });
    }

    // Wizard Back button
    var backBtn = contentEl.querySelector('[data-action="back"]');
    if (backBtn) {
      backBtn.addEventListener('click', function() {
        if (state.step > 1) goToStep(state.step - 1, false);
      });
    }

    // Subscribe
    contentEl.querySelectorAll('[data-action="subscribe"]').forEach(function(btn) {
      btn.addEventListener('click', handleSubscribe);
    });
  }

  // ── Checkout submission ────────────────────────────────────────────
  function handleSubscribe() {
    var pack = bocs.packSizes[state.packIndex];
    var freq = pack && pack.frequencies[state.freqIndex];
    if (!pack || !freq || !canSubscribe(bocs)) return;

    var items = [];
    if (isFixed()) {
      (pack.products || []).forEach(function(p) {
        items.push({
          variantId:     String(p.variantId || p.externalSourceId || ''),
          sellingPlanId: String(freq.sellingPlanId || ''),
          quantity:      p.quantity || 1
        });
      });
    } else {
      Object.keys(state.selectedProducts).forEach(function(pid) {
        var qty = state.selectedProducts[pid];
        if (qty > 0) {
          var p = (pack.products || []).filter(function(pr){ return pr.id === pid; })[0];
          if (p) items.push({
            variantId:     String(p.variantId || p.externalSourceId || ''),
            sellingPlanId: String(freq.sellingPlanId || ''),
            quantity:      qty
          });
        }
      });
    }

    if (!items.length) { showToast('No valid products to subscribe.'); return; }

    var btns = contentEl.querySelectorAll('[data-action="subscribe"]');
    btns.forEach(function(b) {
      b.disabled = true;
      b.innerHTML = '<svg style="width:14px;height:14px;animation:bocs-spin 1s linear infinite;vertical-align:middle" viewBox="0 0 50 50"><circle cx="25" cy="25" r="20" fill="none" stroke="rgba(255,255,255,.4)" stroke-width="4"/><circle cx="25" cy="25" r="20" fill="none" stroke="#fff" stroke-width="4" stroke-dasharray="60 200" stroke-linecap="round"/></svg> Processing…';
    });

    fetch(checkoutUrl, {
      method:  'POST',
      headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
      body:    JSON.stringify({ items: items })
    })
    .then(function(res) { if (!res.ok) throw new Error('HTTP ' + res.status); return res.json(); })
    .then(function(data) {
      root.dispatchEvent(new CustomEvent('bocs:subscribed', {
        bubbles: true,
        detail:  { bocs: bocs, pack: pack, frequency: freq, items: items, response: data }
      }));
      var inner = (data && data.data) || data || {};
      var url   = inner.checkoutUrl || inner.checkout_url || inner.redirectUrl || inner.url || null;
      if (typeof data === 'string' && data.indexOf('http') === 0) url = data;
      if (url) { window.location.href = url; }
      else {
        showToast('Subscription started! ✓');
        btns.forEach(function(b){ b.disabled = false; b.innerHTML = 'Subscribe Now ›'; });
      }
    })
    .catch(function(err) {
      console.warn('[BocsWidget] Checkout error:', err.message);
      showToast('Something went wrong. Please try again.');
      btns.forEach(function(b){ b.disabled = false; b.innerHTML = 'Subscribe Now ›'; });
    });
  }

  function showToast(msg) {
    var t = root.querySelector('.bocs-toast');
    if (!t) return;
    t.textContent = msg; t.classList.add('is-visible');
    setTimeout(function() { t.classList.remove('is-visible'); }, 3000);
  }

  // ── Empty state (no BOCS from API) ─────────────────────────────────
  function showEmpty() {
    loadingEl.style.display = 'none';
    if (contentEl) contentEl.hidden = true;
    if (errorEl) errorEl.hidden = true;
    if (emptyEl) emptyEl.hidden = false;
  }

  // ── Error display (Ah Snap) ─────────────────────────────────────────
  function showError(msg) {
    loadingEl.style.display = 'none';
    if (contentEl) contentEl.hidden = true;
    if (emptyEl) emptyEl.hidden = true;
    var titleEl = errorEl && errorEl.querySelector('.bocs-error__title');
    var msgEl   = errorEl && errorEl.querySelector('.bocs-error__msg');
    if (titleEl) titleEl.textContent = 'Ah snap!';
    if (msgEl)   msgEl.textContent   = msg || 'Something went wrong loading your subscription options. Please refresh the page or try again in a few minutes.';
    if (errorEl) errorEl.hidden = false;
  }

  // ── Init ───────────────────────────────────────────────────────────
  function initWidget(data) {
    if (emptyEl) emptyEl.hidden = true;
    if (errorEl) errorEl.hidden = true;
    bocs = data;

    // Resolve defaults from block settings
    var packSel  = (getBlockSettings().packSelector       || {}).defaultSelection  || 'middle';
    var freqSel  = (getBlockSettings().frequencyPicker    || {}).defaultSelection  || 'best-value-frequency';

    if (bocs.packSizes && bocs.packSizes.length) {
      state.packIndex = packSel === 'first'  ? 0
        : packSel === 'middle' ? Math.floor(bocs.packSizes.length / 2)
        : 0;
      // Clamp
      state.packIndex = Math.min(state.packIndex, bocs.packSizes.length - 1);
    }

    var pack = bocs.packSizes && bocs.packSizes[state.packIndex];
    if (pack && pack.frequencies && pack.frequencies.length) {
      state.freqIndex = freqSel === 'first' ? 0
        : freqSel === 'best-value-frequency' ? bestValueIndex(pack.frequencies)
        : 0;
    }

    injectDynamicStyles(bocs);
    loadingEl.style.display = 'none';
    render();
  }

  // ── Boot: fetch BOCS (Open Search or array), or mock ───────────────
  var apiUrl = root.dataset.apiUrl;
  if (!apiUrl) {
    setTimeout(function() { initWidget(MOCK_BOCS); }, 400);
    return;
  }
  fetch(apiUrl, { method: 'GET', headers: { Accept: 'application/json' } })
    .then(function(res) { if (!res.ok) throw new Error('HTTP ' + res.status); return res.json(); })
    .then(function(json) {
      var list = [];
      if (json && json.hits && Array.isArray(json.hits.hits)) {
        list = json.hits.hits.map(function(h) { return h._source || h; }).filter(Boolean);
      } else if (Array.isArray(json)) {
        list = json;
      } else if (json && Array.isArray(json.data)) {
        list = json.data;
      } else if (json && (json.data || json)) {
        list = [json.data || json];
      }
      if (!list.length) { showEmpty(); return; }
      initWidget(list[0]);
    })
    .catch(function(err) { console.warn('[BocsWidget]', err.message); showError(err.message || undefined); });

})();
</script>

{% schema %}
{
  "name": "BOCS Widget",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "API"
    },
    {
      "type": "text",
      "id": "api_url",
      "label": "BOCS API URL",
      "default": "/apps/customer-dashboard/api/customer-portal/store/bocs",
      "info": "Returns a BOCS object. Widget uses mock data until this is connected."
    },
    {
      "type": "text",
      "id": "checkout_url",
      "label": "Checkout API URL",
      "default": "/apps/customer-dashboard/api/customer-portal/store/checkout",
      "info": "POSTs { items: [{ variantId, sellingPlanId, quantity }] } on subscribe."
    }
  ]
}
{% endschema %}
