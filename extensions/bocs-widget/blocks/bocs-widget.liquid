  function resolveTransSpeed() {
    var s = getFlow().transitionSpeed || 'normal';
    if (s === 'slow')   return 500;
    if (s === 'normal') return 300;
    if (s === 'fast')   return 150;
    var n = parseInt(s);
    return isNaN(n) ? 300 : n;
  }

  // ── Utilities ──────────────────────────────────────────────────────
  function esc(str) {
    return String(str || '')
      .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }

  // Scope full CSS rules with #blockId so API can send selectors without knowing block id
  function scopeCssRules(css, scopeId) {
    var out = [], i = 0, len = (css || '').length;
    while (i < len) {
      while (i < len && /[\s\n\r]/.test(css[i])) i++;
      if (i >= len) break;
      if (css.substr(i, 2) === '/*') {
        var end = css.indexOf('*/', i + 2);
        if (end === -1) break;
        out.push(css.substring(i, end + 2));
        i = end + 2;
        continue;
      }
      var selStart = i;
      var brace = css.indexOf('{', i);
      if (brace === -1) break;
      var selector = css.substring(selStart, brace).trim();
      var depth = 1;
      i = brace + 1;
      while (i < len && depth > 0) {
        if (css[i] === '{') depth++;
        else if (css[i] === '}') depth--;
        i++;
      }
      var block = css.substring(brace + 1, i - 1);
      var scopedSel = selector.split(',').map(function(s) {
        return (scopeId + ' ' + s.trim()).replace(/\s+/g, ' ').trim();
      }).join(', ');
      out.push(scopedSel + ' { ' + block + ' }');
    }
    return out.join('\n');
  }

  function fmt(n) {
    var v = parseFloat(n || 0);
    return v === 0 ? 'Free' : '$' + v.toFixed(2);
