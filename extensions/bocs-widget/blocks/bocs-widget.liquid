  function bestValueIndex(frequencies) {
    var max = -1, idx = 0;
    (frequencies || []).forEach(function(f, i) {
      var d = parseFloat(f.discount) || 0;
      if (d > max) { max = d; idx = i; }
    });
    return idx;
  }

  function calcPackSubtotal(pack) {
    return (pack.products || []).reduce(function(s, p) {
      return s + (p.price || 0) * (p.quantity || 1);
    }, 0);
  }

  function calcCustomSubtotal(pack, sel) {
    return (pack.products || []).reduce(function(s, p) {
      return s + (p.price || 0) * (sel[p.id] || 0);
    }, 0);
  }

  function applyDiscount(subtotal, freq) {
    var d = parseFloat(freq && freq.discount || 0) || 0;
